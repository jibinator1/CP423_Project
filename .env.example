# =============================================================================
# CP423 Clinical IR System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# ALL services used below are FREE TIER. No paid subscriptions required.
# =============================================================================

# --- Groq API (Free) ---
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# --- Supabase (Free Tier) ---
# Create a project at: https://supabase.com/
# Go to Settings → API to find these values
SUPABASE_URL=https://your-project.supabase.co/
SUPABASE_KEY=your-supabase-anon-key-here

# --- Hugging Face (Free) ---
# Create a token at: https://huggingface.co/settings/tokens
# Required for Pyannote speaker diarization model access
HF_AUTH_TOKEN=hf_your-token-here

# --- LiveKit Cloud (Free Tier) ---
# Sign up at: https://livekit.io/
# Create a project to get these values
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- Internal Auth Token ---
# Used for securing the ingest endpoint (can be any random string)
LIVEKIT_INGEST_TOKEN=my_secret_ingest_token

# --- n8n Webhook URL (default) ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/livekit-segment-ingest
